
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resumidor de Textos</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            padding: 40px;
            max-width: 900px;
            width: 100%;
        }

        .header {
            text-align: center;
            margin-bottom: 40px;
        }

        .header h1 {
            font-size: 2.5em;
            color: #333;
            margin-bottom: 10px;
        }

        .header p {
            color: #666;
            font-size: 1em;
        }

        .content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 30px;
        }

        .section {
            display: flex;
            flex-direction: column;
        }

        .section label {
            font-weight: 600;
            color: #333;
            margin-bottom: 10px;
            font-size: 1.1em;
        }

        .char-counter {
            font-size: 0.85em;
            color: #999;
            margin-top: 5px;
        }

        .char-counter.warning {
            color: #ff6b6b;
            font-weight: 600;
        }

        textarea {
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            padding: 15px;
            font-family: inherit;
            font-size: 1em;
            resize: none;
            height: 250px;
            transition: all 0.3s ease;
            color: #333;
        }

        textarea:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        #outputText {
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            padding: 15px;
            height: 250px;
            overflow-y: auto;
            background-color: #f9f9f9;
            color: #333;
            line-height: 1.6;
            white-space: pre-wrap;
            word-wrap: break-word;
            animation: slideIn 0.5s ease;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .button-group {
            display: flex;
            gap: 12px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        button {
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            font-size: 1em;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            flex: 1;
            min-width: 150px;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        .btn-secondary {
            background: #f0f0f0;
            color: #333;
            flex: 1;
            min-width: 150px;
        }

        .btn-secondary:hover {
            background: #e0e0e0;
            transform: translateY(-2px);
        }

        .btn-secondary:active {
            transform: translateY(0);
        }

        .btn-primary:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        .loading {
            display: none;
            text-align: center;
            color: #667eea;
            font-weight: 600;
            margin: 20px 0;
        }

        .loading.active {
            display: block;
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse {
            0%, 100% {
                opacity: 1;
            }
            50% {
                opacity: 0.5;
            }
        }

        .spinner {
            display: inline-block;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: #667eea;
            margin-right: 8px;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .message {
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            display: none;
            animation: slideIn 0.3s ease;
        }

        .message.show {
            display: block;
        }

        .message.error {
            background-color: #ffe0e0;
            color: #c92a2a;
            border-left: 4px solid #c92a2a;
        }

        .message.warning {
            background-color: #fff3cd;
            color: #856404;
            border-left: 4px solid #ffc107;
        }

        .message.success {
            background-color: #d4edda;
            color: #155724;
            border-left: 4px solid #28a745;
        }

        .stats {
            font-size: 0.9em;
            color: #999;
            margin-top: 10px;
        }

        .stats span {
            font-weight: 600;
            color: #667eea;
        }

        @media (max-width: 768px) {
            .content {
                grid-template-columns: 1fr;
            }

            .container {
                padding: 20px;
            }

            .header h1 {
                font-size: 2em;
            }

            textarea, #outputText {
                height: 200px;
            }

            .button-group {
                flex-direction: column;
            }

            .btn-primary, .btn-secondary {
                min-width: auto;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>📝 Resumidor de Textos</h1>
            <p>Cole seu texto e receba um resumo automático e inteligente</p>
        </div>

        <div id="messageContainer" class="message"></div>

        <div class="content">
            <div class="section">
                <label for="inputText">Texto Original</label>
                <textarea id="inputText" placeholder="Cole ou digite seu texto aqui..."></textarea>
                <div class="char-counter">
                    <span id="charCount">0</span> / <span id="charMax">5000</span> caracteres
                </div>
            </div>

            <div class="section">
                <label for="outputText">Resumo Gerado</label>
                <div id="outputText">Seu resumo aparecerá aqui...</div>
                <div class="stats">
                    Redução: <span id="reductionPercent">0%</span>
                </div>
            </div>
        </div>

        <div class="loading" id="loading">
            <span class="spinner"></span>Gerando resumo...
        </div>

        <div class="button-group">
            <button class="btn-primary" id="summarizeBtn">Resumir</button>
            <button class="btn-secondary" id="clearBtn">Limpar</button>
        </div>
    </div>

    <script>
        // Configurações
        const MAX_CHARS = 5000;
        const REDUCTION_TARGET = 0.35; // 35% do tamanho original

        // Elementos do DOM
        const inputText = document.getElementById('inputText');
        const outputText = document.getElementById('outputText');
        const summarizeBtn = document.getElementById('summarizeBtn');
        const clearBtn = document.getElementById('clearBtn');
        const charCount = document.getElementById('charCount');
        const charMax = document.getElementById('charMax');
        const loading = document.getElementById('loading');
        const messageContainer = document.getElementById('messageContainer');
        const reductionPercent = document.getElementById('reductionPercent');

        // Atualizar contador de caracteres
        inputText.addEventListener('input', function() {
            const length = this.value.length;
            charCount.textContent = length;

            const counter = document.querySelector('.char-counter');
            if (length > MAX_CHARS) {
                counter.classList.add('warning');
                showMessage(`Limite de ${MAX_CHARS} caracteres ultrapassado!`, 'warning');
                this.value = this.value.substring(0, MAX_CHARS);
                charCount.textContent = MAX_CHARS;
            } else {
                counter.classList.remove('warning');
                hideMessage();
            }
        });

        // Botão Resumir
        summarizeBtn.addEventListener('click', function() {
            const text = inputText.value.trim();

            if (text.length === 0) {
                showMessage('Por favor, insira um texto para resumir.', 'error');
                return;
            }

            if (text.length < 50) {
                showMessage('O texto deve ter pelo menos 50 caracteres para gerar um resumo.', 'warning');
                return;
            }

            // Simular processamento
            summarizeBtn.disabled = true;
            loading.classList.add('active');
            hideMessage();

            // Simular delay de processamento (1-2 segundos)
            setTimeout(() => {
                const summary = generateSummary(text);
                outputText.textContent = summary;
               
                const reductionRatio = (1 - (summary.length / text.length)) * 100;
                reductionPercent.textContent = Math.round(reductionRatio) + '%';

                loading.classList.remove('active');
                summarizeBtn.disabled = false;
                showMessage('Resumo gerado com sucesso!', 'success');
            }, 1500);
        });

        // Botão Limpar
        clearBtn.addEventListener('click', function() {
            inputText.value = '';
            outputText.textContent = 'Seu resumo aparecerá aqui...';
            charCount.textContent = '0';
            reductionPercent.textContent = '0%';
            hideMessage();
            summarizeBtn.disabled = false;
            inputText.focus();
        });

        // Função para gerar resumo
        function generateSummary(text) {
            // Dividir em sentenças
            const sentences = text.match(/[^.!?]+[.!?]+/g) || [text];
           
            if (sentences.length === 0) {
                return text.substring(0, Math.floor(text.length * REDUCTION_TARGET));
            }

            // Limpar e avaliar sentenças
            const cleanSentences = sentences.map(s => s.trim()).filter(s => s.length > 0);
           
            if (cleanSentences.length <= 2) {
                return text.substring(0, Math.floor(text.length * 0.6));
            }

            // Calcular pontuação de cada sentença
            const scoredSentences = cleanSentences.map((sentence, index) => {
                let score = 0;

                // Bônus por posição (primeira e última são importantes)
                if (index === 0) score += 2;
                if (index === cleanSentences.length - 1) score += 1;

                // Bônus por comprimento (sentenças médias são mais informativas)
                const wordCount = sentence.split(/\s+/).length;
                if (wordCount >= 5 && wordCount <= 25) score += 1;

                // Bônus por palavras-chave
                const keywords = ['importante', 'significante', 'principal', 'crucial', 'essencial', 'determina', 'conclui', 'resultado', 'impacto', 'descoberta', 'prove', 'demonstra'];
                keywords.forEach(keyword => {
                    if (sentence.toLowerCase().includes(keyword)) score += 0.5;
                });

                return { sentence: sentence + ' ', score: score };
            });

            // Selecionar sentenças com maior pontuação
            const targetSentences = Math.max(2, Math.ceil(cleanSentences.length * REDUCTION_TARGET));
            const topSentences = scoredSentences
                .sort((a, b) => b.score - a.score)
                .slice(0, targetSentences)
                .sort((a, b) => cleanSentences.indexOf(a.sentence.trim()) - cleanSentences.indexOf(b.sentence.trim()));

            // Montar resumo mantendo ordem original
            let summary = topSentences.map(item => item.sentence).join('');
           
            // Garantir que o resumo tenha tamanho mínimo
            if (summary.length < 100 && text.length > 200) {
                const additionalSentences = scoredSentences
                    .slice(targetSentences, targetSentences + 2)
                    .map(item => item.sentence)
                    .join('');
                summary += additionalSentences;
            }

            return summary.trim();
        }

        // Função para mostrar mensagem
        function showMessage(text, type) {
            messageContainer.textContent = text;
            messageContainer.className = 'message show ' + type;
        }

        // Função para esconder mensagem
        function hideMessage() {
            messageContainer.classList.remove('show');
        }

        // Atualizar max chars na exibição
        charMax.textContent = MAX_CHARS;

        // Focus inicial
        inputText.focus();
    </script>
</body>
</html>
